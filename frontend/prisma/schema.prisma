generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  hashedPassword String
  fullName       String
  role           UserRole         @default(DOCTOR_GENERAL)
  isActive       Boolean          @default(true)
  companyId      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  auditLogs      AuditLog[]
  performedTests EventTest[]
  signatures     MedicalVerdict[]
  company        Company?         @relation(fields: [companyId], references: [id])

  @@map("users")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]

  @@map("tenants")
}

model Branch {
  id                 String         @id @default(uuid())
  name               String
  address            String?
  phone              String?
  managerName        String?
  tenantId           String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  closingTime        String         @default("17:00")
  hourlyCapacity     Int            @default(15)
  openingTime        String         @default("07:00")
  appointments       Appointment[]
  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  companies          Company[]
  allowedByCompanies Company[]      @relation("CompanyAllowedBranches")
  events             MedicalEvent[]
  workers            Worker[]

  @@map("branches")
}

model Company {
  id              String           @id @default(uuid())
  name            String
  rfc             String?
  address         String?
  contactName     String?
  email           String?
  phone           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  defaultBranchId String?
  appointments    Appointment[]
  defaultBranch   Branch?          @relation(fields: [defaultBranchId], references: [id])
  allowedBranches Branch[]         @relation("CompanyAllowedBranches")
  billedEvents    MedicalEvent[]   @relation("BillingCompany")
  medicalProfiles MedicalProfile[]
  jobPositions     JobPosition[]
  users           User[]
  workers         Worker[]

  @@map("companies")
}

model Worker {
  id              String           @id @default(uuid())
  universalId     String           @unique
  firstName       String
  lastName        String
  nationalId      String?
  dob             DateTime?
  email           String?
  phone           String?
  companyId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  branchId        String?
  appointments    Appointment[]
  clinicalHistory ClinicalHistory?
  medicalHistory  MedicalEvent[]
  jobPositionId    String?
  branch          Branch?          @relation(fields: [branchId], references: [id])
  company         Company?         @relation(fields: [companyId], references: [id])
  jobPosition     JobPosition?     @relation(fields: [jobPositionId], references: [id])

  @@map("workers")
}

model ClinicalHistory {
  id          String   @id @default(uuid())
  workerId    String   @unique
  data        Json     @default("{}")
  lastUpdated DateTime @default(now())
  updatedAt   DateTime @updatedAt
  worker      Worker   @relation(fields: [workerId], references: [id])

  @@map("clinical_histories")
}

model Service {
  id              String            @id @default(uuid())
  name            String
  code            String            @unique
  description     String?
  price           Decimal?
  category        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ProfileServices ProfileServices[]

  @@map("services")
}

model ServiceProfile {
  id              String            @id @default(uuid())
  name            String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ProfileServices ProfileServices[]

  @@map("service_profiles")
}

model TestCategory {
  id          String        @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tests       MedicalTest[]

  @@map("test_categories")
}

model MedicalTest {
  id           String            @id @default(uuid())
  code         String            @unique
  name         String
  categoryId   String
  options      Json              @default("[]")
  targetGender GenderRestriction @default(ALL)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  eventTests   EventTest[]
  category     TestCategory      @relation(fields: [categoryId], references: [id])
  profiles     ProfileTest[]

  @@map("medical_tests")
}

model MedicalProfile {
  id           String        @id @default(uuid())
  name         String
  companyId    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments  Appointment[]
  company       Company?      @relation(fields: [companyId], references: [id])
  jobPositions  JobPosition[]
  tests         ProfileTest[]

  @@map("medical_profiles")
}

model ProfileTest {
  id        String         @id @default(uuid())
  profileId String
  testId    String
  profile   MedicalProfile @relation(fields: [profileId], references: [id])
  test      MedicalTest    @relation(fields: [testId], references: [id])

  @@unique([profileId, testId])
  @@map("profile_tests")
}

model EventTest {
  id               String          @id @default(uuid())
  eventId          String
  testId           String?
  testNameSnapshot String
  selectedOption   String?
  status           EventTestStatus @default(PENDING)
  performedById    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  event            MedicalEvent    @relation(fields: [eventId], references: [id])
  performedBy      User?           @relation(fields: [performedById], references: [id])
  test             MedicalTest?    @relation(fields: [testId], references: [id])

  @@map("event_tests")
}

model MedicalEvent {
  id               String          @id @default(uuid())
  status           EventStatus     @default(SCHEDULED)
  workerId         String
  branchId         String
  checkInDate      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  appointmentId    String?         @unique
  billingCompanyId String?
  eventTests       EventTest[]
  labs             LabRecord[]
  appointment      Appointment?    @relation(fields: [appointmentId], references: [id])
  billingCompany   Company?        @relation("BillingCompany", fields: [billingCompanyId], references: [id])
  branch           Branch          @relation(fields: [branchId], references: [id])
  worker           Worker          @relation(fields: [workerId], references: [id])
  exam             MedicalExam?
  verdict          MedicalVerdict?
  studies          StudyRecord[]

  @@map("medical_events")
}

model MedicalExam {
  id               String       @id @default(uuid())
  eventId          String       @unique
  weight           Float?
  height           Float?
  bloodPressure    String?
  heartRate        Int?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  eyeAcuityData    Json?        @default("{}")
  physicalExamData Json?        @default("{}")
  somatometryData  Json?        @default("{}")
  vitalSignsData   Json?        @default("{}")
  event            MedicalEvent @relation(fields: [eventId], references: [id])

  @@map("medical_exams")
}

model StudyRecord {
  id             String       @id @default(uuid())
  eventId        String
  serviceName    String
  fileUrl        String?
  extractedData  Json?
  aiPrediction   String?
  isCompleted    Boolean      @default(false)
  validatorNotes String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  event          MedicalEvent @relation(fields: [eventId], references: [id])

  @@map("study_records")
}

model LabRecord {
  id            String       @id @default(uuid())
  eventId       String
  serviceName   String
  fileUrl       String?
  extractedData Json?
  aiPrediction  String?
  isCompleted   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  event         MedicalEvent @relation(fields: [eventId], references: [id])

  @@map("lab_records")
}

model MedicalVerdict {
  id              String       @id @default(uuid())
  eventId         String       @unique
  finalDiagnosis  String
  recommendations String?
  validatorId     String
  signedAt        DateTime     @default(now())
  signatureHash   String?
  pdfUrl          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  event           MedicalEvent @relation(fields: [eventId], references: [id])
  validator       User         @relation(fields: [validatorId], references: [id])

  @@map("medical_verdicts")
}

model Appointment {
  id               String            @id @default(uuid())
  workerId         String
  companyId        String
  branchId         String
  scheduledAt      DateTime
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expedientId      String?           @unique
  qrCode           String?
  source           String            @default("SUCURSAL")
  serviceProfileId String?
  branch           Branch            @relation(fields: [branchId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  serviceProfile   MedicalProfile?   @relation(fields: [serviceProfileId], references: [id])
  worker           Worker            @relation(fields: [workerId], references: [id])
  medicalEvents    MedicalEvent?

  @@map("appointments")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ProfileServices {
  A                String
  B                String
  services         Service        @relation(fields: [A], references: [id], onDelete: Cascade)
  service_profiles ServiceProfile @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_ProfileServices_AB_unique")
  @@index([B], map: "_ProfileServices_B_index")
  @@map("_ProfileServices")
}

// IMPL-20260313-05: Modelo de Puestos de Trabajo para arquitectura B2B
model JobPosition {
  id               String          @id @default(uuid())
  name             String
  description      String?
  companyId        String
  defaultProfileId String?

  company          Company         @relation(fields: [companyId], references: [id])
  defaultProfile   MedicalProfile? @relation(fields: [defaultProfileId], references: [id])
  workers          Worker[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("job_positions")
}

enum UserRole {
  ADMIN
  RECEPTIONIST
  DOCTOR_GENERAL
  DOCTOR_VALIDATOR
  CAPTURIST
  COMPANY_CLIENT
}

enum GenderRestriction {
  ALL
  MALE
  FEMALE
}

enum EventTestStatus {
  PENDING
  COMPLETED
  SKIPPED
  CANCELLED
}

enum EventStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  VALIDATING
  COMPLETED
  CANCELED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}
