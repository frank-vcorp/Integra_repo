generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// CORE / ACCESS
// --------------------------------------------------------

enum UserRole {
  ADMIN
  RECEPTIONIST
  DOCTOR_GENERAL
  DOCTOR_VALIDATOR
  CAPTURIST
  COMPANY_CLIENT
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String // Hashed with bcryptjs
  fullName       String
  role           UserRole @default(DOCTOR_GENERAL)
  isActive       Boolean  @default(true)

  // Multi-tenant: Si el usuario es COMPANY_CLIENT, debe estar vinculado a una empresa
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Relations
  signatures     MedicalVerdict[] // Dictamenes firmados por este usuario
  auditLogs      AuditLog[] // Acciones registradas en auditoría
  performedTests EventTest[] // Pruebas realizadas/validadas por este usuario (ARCH-20260313-01)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Tenant {
  id     String @id @default(uuid())
  name   String
  config Json?

  branches Branch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

model Branch {
  id          String  @id @default(uuid())
  name        String
  address     String?
  phone       String?
  managerName String?

  // Configuración de Capacidad y Horarios
  hourlyCapacity Int    @default(15) // Pacientes por hora
  openingTime    String @default("07:00") // Hora de apertura (HH:mm)
  closingTime    String @default("17:00") // Hora de cierre (HH:mm)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  events       MedicalEvent[]
  appointments Appointment[]
  companies    Company[] // Empresas que tienen esta sucursal por defecto
  workers      Worker[] // Trabajadores asignados a esta sucursal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("branches")
}

// --------------------------------------------------------
// CLIENTES Y TRABAJADORES
// --------------------------------------------------------

model Company {
  id          String  @id @default(uuid())
  name        String
  rfc         String? // Tax ID
  address     String?
  contactName String?
  email       String?
  phone       String?

  // Sucursal predeterminada para esta empresa
  defaultBranchId String?
  defaultBranch   Branch? @relation(fields: [defaultBranchId], references: [id])

  workers         Worker[]
  users           User[] // Usuarios CLIENT vinculados a esta empresa
  appointments    Appointment[]
  medicalProfiles MedicalProfile[] // Perfiles exclusivos de esta empresa (ARCH-20260313-01)
  billedEvents    MedicalEvent[]   @relation("BillingCompany") // Eventos facturados a esta empresa (ARCH-20260313-01)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model Worker {
  id String @id @default(uuid())

  // ID Universal (Vital para el sistema)
  universalId String @unique

  firstName  String
  lastName   String
  nationalId String? // CURP/DNI
  dob        DateTime? // Date of Birth
  email      String?
  phone      String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Sucursal asignada (heredada de la empresa o asignada manualmente)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  medicalHistory  MedicalEvent[]
  appointments    Appointment[]
  clinicalHistory ClinicalHistory?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workers")
}

// --------------------------------------------------------
// CLINICAL HISTORY (PERSISTENT / BACKGROUND)
// --------------------------------------------------------

model ClinicalHistory {
  id       String @id @default(uuid())
  workerId String @unique
  worker   Worker @relation(fields: [workerId], references: [id])

  // "Schema-Driven" Storage
  // Modules: Pathological, NonPathological, Hereditary, Gynecological, etc.
  // Structure defined in: src/config/clinical-schemas/*.ts
  data Json @default("{}")

  lastUpdated DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("clinical_histories")
}

// --------------------------------------------------------
// SERVICIOS Y CATÁLOGOS
// --------------------------------------------------------

model Service {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique // Internal code e.g. "AUD-01"
  description String?
  price       Decimal?
  category    String? // 'Medical', 'Lab', 'Package'

  // Relation to profiles (ManyToMany via implicit or explicit? Implicit is fine for now)
  profiles ServiceProfile[] @relation("ProfileServices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}

model ServiceProfile {
  id          String  @id @default(uuid())
  name        String // e.g. "Batería Ingreso Operativo"
  description String?

  services Service[] @relation("ProfileServices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_profiles")
}

// --------------------------------------------------------
// CATÁLOGO CLÍNICO Y PERFILES B2B (ARCH-20260313-01)
// --------------------------------------------------------

enum GenderRestriction {
  ALL
  MALE
  FEMALE
}

enum EventTestStatus {
  PENDING
  COMPLETED
  SKIPPED
  CANCELLED
}

model TestCategory {
  id          String  @id @default(uuid())
  name        String
  description String?

  tests MedicalTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("test_categories")
}

model MedicalTest {
  id   String @id @default(uuid())
  code String @unique
  name String

  categoryId String
  category   TestCategory @relation(fields: [categoryId], references: [id])

  options      Json              @default("[]")
  targetGender GenderRestriction @default(ALL)

  profiles   ProfileTest[]
  eventTests EventTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_tests")
}

model MedicalProfile {
  id   String @id @default(uuid())
  name String

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  tests        ProfileTest[]
  appointments Appointment[] // Citas que usan este perfil (IMPL-20260313-04)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_profiles")
}

model ProfileTest {
  id String @id @default(uuid())

  profileId String
  profile   MedicalProfile @relation(fields: [profileId], references: [id])

  testId String
  test   MedicalTest @relation(fields: [testId], references: [id])

  @@unique([profileId, testId])
  @@map("profile_tests")
}

model EventTest {
  id String @id @default(uuid())

  eventId String
  event   MedicalEvent @relation(fields: [eventId], references: [id])

  testId String?
  test   MedicalTest? @relation(fields: [testId], references: [id])

  testNameSnapshot String
  selectedOption   String?
  status           EventTestStatus @default(PENDING)

  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("event_tests")
}

// --------------------------------------------------------
// FLUJO MEDICO (EXPEDIENTE)
// --------------------------------------------------------

enum EventStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  VALIDATING
  COMPLETED
  CANCELED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

model MedicalEvent {
  id     String      @id @default(uuid())
  status EventStatus @default(SCHEDULED)

  workerId String
  worker   Worker @relation(fields: [workerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  checkInDate DateTime?

  // Sub-documents / Components of the Event
  exam MedicalExam?

  // Array of studies/labs linked to this event
  studies StudyRecord[]
  labs    LabRecord[]

  // Final Output
  verdict MedicalVerdict?

  // Relación opcional 1:1 con Appointment
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId String?      @unique

  // B2B Reseller: empresa a quién se factura (puede ser diferente al employer del worker) (ARCH-20260313-01)
  billingCompanyId String?
  billingCompany   Company? @relation("BillingCompany", fields: [billingCompanyId], references: [id])

  // Pruebas instanciadas para este evento (ARCH-20260313-01)
  eventTests EventTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_events")
}

model MedicalExam {
  id      String       @id @default(uuid())
  eventId String       @unique
  event   MedicalEvent @relation(fields: [eventId], references: [id])

  // ------------------------------------------------------
  // MODULAR DYNAMIC SECTIONS (JSON-Based)
  // ------------------------------------------------------

  // Module 1: Somatometry (Weight, Height, BMI, Waist, etc.)
  somatometryData Json? @default("{}")

  // Module 2: Vital Signs (BP, HR, RR, Temp, SatO2)
  vitalSignsData Json? @default("{}")

  // Module 3: Visual/Eye Acuity (Snellen, Ishihara, Campimetry)
  eyeAcuityData Json? @default("{}")

  // Module 4: Physical Exam (Head, Neck, Chest, Abdomen, Limbs...)
  physicalExamData Json? @default("{}")

  // Legacy/Cache fields (Optional, kept for backward compat if needed)
  weight        Float?
  height        Float?
  bloodPressure String?
  heartRate     Int?
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_exams")
}

model StudyRecord {
  id      String       @id @default(uuid())
  eventId String
  event   MedicalEvent @relation(fields: [eventId], references: [id])

  serviceName String // Copia del nombre del servicio para histórico

  // Archivo
  fileUrl String? // Path to PDF/Image

  // AI & Data
  extractedData Json? // OCR results
  aiPrediction  String? // AI suggestion

  // Status
  isCompleted    Boolean @default(false)
  validatorNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("study_records")
}

model LabRecord {
  id      String       @id @default(uuid())
  eventId String
  event   MedicalEvent @relation(fields: [eventId], references: [id])

  serviceName String

  fileUrl String?

  extractedData Json?
  aiPrediction  String?

  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lab_records")
}

model MedicalVerdict {
  id      String       @id @default(uuid())
  eventId String       @unique
  event   MedicalEvent @relation(fields: [eventId], references: [id])

  finalDiagnosis  String  @db.Text
  recommendations String? @db.Text

  // Firma
  validatorId   String
  validator     User     @relation(fields: [validatorId], references: [id])
  signedAt      DateTime @default(now())
  signatureHash String? // Digital signature string

  pdfUrl String? // Generado final

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_verdicts")
}

// --------------------------------------------------------
// CITAS Y AUDITORÍA (Sprint 7)
// --------------------------------------------------------

model Appointment {
  id String @id @default(uuid())

  // ID de papeleta (formato EXP-YYYYNNN)
  expedientId String? @unique

  workerId String
  worker   Worker @relation(fields: [workerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  scheduledAt DateTime // Fecha y hora de la cita
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?           @db.Text

  // Origen de la cita
  source String @default("SUCURSAL") // TELEFONO, WHATSAPP, CORREO, SUCURSAL, OTRO

  // Perfil médico B2B asignado a esta cita (IMPL-20260313-04)
  // Al hacer Check-in, sus ProfileTest se instancian como EventTest
  serviceProfileId String?
  serviceProfile   MedicalProfile? @relation(fields: [serviceProfileId], references: [id])

  // Documento generado (QR + Pase)
  qrCode String? @db.Text

  // Relación opcional 1:1 con MedicalEvent
  medicalEvents MedicalEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model AuditLog {
  id String @id @default(uuid())

  userId String? // Quién realizó la acción (opcional, por si es el sistema)
  user   User?   @relation(fields: [userId], references: [id])

  action   String // ej. "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity   String // ej. "Worker", "Appointment", "MedicalEvent"
  entityId String? // ID de la entidad afectada

  details   Json? // Datos adicionales (ej. valores antes/después)
  ipAddress String? // IP del cliente

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
